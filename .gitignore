# =============================
# Visual Studio / .NET / C# .gitignore
# =============================

# Build Folders
bin/
obj/
out/

# Visual Studio files
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# Rider / JetBrains files
.idea/
*.iml

# NuGet Packages
*.nupkg
packages/
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET / Web
*.log
*.vspscc
*.vssscc
.vscode/

# OS generated files
Thumbs.db
.DS_Store
desktop.ini

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml

# Resharper
_ReSharper*/
*.DotSettings.user

# Node / frontend (if any)
node_modules/

# Others
*.cache
*.tmp
*.bak
*.swp